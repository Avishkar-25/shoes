
<%- include('navbar.ejs') %>

<div class="container mt-5">

<h2 class="mb-4 text-center fw-bold">Order Tracking</h2>

<div class="card p-4 shadow-sm rounded-4">

<h4 class="mb-2">
Order ID: <span class="text-primary">#<%= order.order_id %></span>
</h4>

<p>Status: <strong class="text-capitalize"><%= order.order_status %></strong></p>

<hr>

<!-- Order Timeline -->

<div class="track">

<div class="step active">
<div class="icon"><i class="bi bi-cart-check-fill"></i></div>
<div class="text">Order Placed</div>
</div>

<div class="step <%= order.order_status=='Dispatched' || order.order_status=='Delivered' ? 'active' : '' %>">
<div class="icon"><i class="bi bi-truck"></i></div>
<div class="text">Dispatched</div>
</div>

<div class="step <%= order.order_status=='Delivered' ? 'active' : '' %>">
<div class="icon"><i class="bi bi-house-door-fill"></i></div>
<div class="text">Delivered</div>
</div>

</div>

<!-- Truck Tracking -->

<div class="truck-container">

<div class="road"></div>

<div class="truck" id="truck">🚚</div>

</div>

<!-- Cancelled -->

<% if(order.order_status=='cancelled'){ %>

<div class="alert alert-danger mt-4 text-center fw-bold">
<i class="bi bi-x-circle-fill me-2"></i>
Order Cancelled
</div>

<% } %>

<!-- Refunded -->

<% if(order.order_status=='Refunded'){ %>

<div class="alert alert-info mt-4 text-center fw-bold">
<i class="bi bi-currency-exchange me-2"></i>
Amount Refunded
</div>

<% } %>

</div>

</div>

<!-- OTP Delivery Confirm -->

<% if(order.order_status=='Dispatched'){ %>

<div class="container mt-4">

<h5 class="fw-bold">Confirm Delivery</h5>

<form action="/verify_delivery_otp" method="post">

<input type="hidden" name="order_id" value="<%=order.order_id%>">

<input type="text"
name="otp"
class="form-control"
placeholder="Enter Delivery OTP">

<button class="btn btn-success mt-2">
Confirm Delivery
</button>

</form>

</div>

<% } %>

<!-- Delivery Location -->

<div class="container mt-4">

<h5 class="fw-bold">Delivery Location</h5>

<div class="alert alert-secondary">

<p class="mb-1">
<i class="bi bi-geo-alt-fill text-danger"></i>
City : <strong><%= order.city || "Aurangabad" %></strong>
</p>

<p class="mb-1">
Address : <strong><%= order.address || "Customer Address" %></strong>
</p>

<p class="mb-0">
Pincode : <strong><%= order.pincode || "431001" %></strong>
</p>

</div>

</div>

<!-- Rating After Delivery -->

<% if(order.order_status=='Delivered'){ %>

<div class="container mt-4 text-center">

<h5>Rate Your Order</h5>

<div class="rating">

<span onclick="rate(1)">⭐</span>
<span onclick="rate(2)">⭐</span>
<span onclick="rate(3)">⭐</span>
<span onclick="rate(4)">⭐</span>
<span onclick="rate(5)">⭐</span>

</div>

</div>

<% } %>

<script>

var status = "<%= order.order_status %>";

var truck = document.getElementById("truck");

if(status=="Pending"){
truck.style.left="0%";
}

if(status=="Dispatched"){
truck.style.left="45%";
}

if(status=="Delivered"){
truck.style.left="90%";
}

function rate(stars){
alert("You rated " + stars + " stars");
}

</script>
<% if(order.order_status=='Dispatched'){ %>

<div class="alert alert-warning mt-3">

Delivery OTP :
<strong><%= order.delivery_otp %></strong>

</div>

<% } %>
<style>

.track{
display:flex;
justify-content:space-between;
margin-top:40px;
}

.step{
text-align:center;
flex:1;
}

.step .icon{
width:50px;
height:50px;
background:#ddd;
border-radius:50%;
display:inline-flex;
align-items:center;
justify-content:center;
font-size:1.3rem;
color:#fff;
margin:auto;
}

.step.active .icon{
background:linear-gradient(135deg,#28a745,#20c997);
}

.step .text{
margin-top:10px;
font-size:14px;
}

.truck-container{
position:relative;
height:60px;
margin-top:20px;
}

.road{
width:100%;
height:4px;
background:#ccc;
position:absolute;
top:30px;
}

.truck{
position:absolute;
top:5px;
font-size:35px;
left:0;
transition:left 1s ease;
}

.rating span{
font-size:30px;
cursor:pointer;
}

</style>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

<%- include('footer.ejs') %>

