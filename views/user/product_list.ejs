<%- include('navbar.ejs') %>

<div class="container my-5">
  <div class="row g-4">
    <% for (var i = 0; i < products.length; i++) { %>
      <div class="col-sm-6 col-md-4 col-lg-3">
        <div class="card product-card h-100 shadow border-0 rounded-4">
          <div class="position-relative overflow-hidden">
            <img src="/product/<%= products[i].product_main_image %>" class="card-img-top" alt="<%= products[i].product_name %>">
            <% if(products[i].is_new) { %>
              <span class="badge bg-danger position-absolute top-0 start-0 m-2 px-3 py-2">New</span>
            <% } %>
            <% if(products[i].discount) { %>
              <span class="badge bg-success position-absolute top-0 end-0 m-2 px-3 py-2">-<%= products[i].discount %>%</span>
            <% } %>
          </div>

          <div class="card-body text-center p-3">
            <h6 class="card-title fw-semibold mb-1"><%= products[i].product_name %></h6>
            <p class="text-muted mb-2" style="font-size: 0.85rem;"><%= products[i].category %></p>
            <h5 class="text-primary fw-bold mb-2">₹<%= products[i].product_price %></h5>
            <% if(products[i].rating) { %>
              <small class="text-warning mb-2 d-block">⭐ <%= products[i].rating %> (<%= products[i].reviews %>)</small>
            <% } %>
            <div class="d-grid">
              <a href="/product_details/<%=products[i].product_id%>" class="btn btn-primary btn-sm fw-semibold">Buy Now</a>
            </div>
          </div>
        </div>
      </div>
    <% } %>
  </div>
</div>

<style>
/* Card hover animation */
.product-card {
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    cursor: pointer;
}
.product-card:hover {
    transform: translateY(-10px) scale(1.03);
    box-shadow: 0 20px 30px rgba(0,0,0,0.25);
}

/* Image fixed size with zoom */
.product-card img {
    width: 100%;
    height: 250px;
    object-fit: cover;
    transition: transform 0.3s ease;
    border-top-left-radius: 0.5rem;
    border-top-right-radius: 0.5rem;
}
.product-card:hover img {
    transform: scale(1.1);
}

/* Badge pop effect */
.product-card .badge {
    transition: transform 0.3s ease;
}
.product-card:hover .badge {
    transform: scale(1.2);
}

/* Button hover */
.product-card .btn-primary {
    transition: all 0.3s ease;
}
.product-card .btn-primary:hover {
    background-color: #0d6efdcc;
    transform: translateY(-2px);
}

/* Card title */
.card-title {
    font-size: 1rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}
</style>

<%- include('footer.ejs') %>
