<%- include('navbar.ejs') %>

<div class="container my-5">

<div class="d-flex justify-content-between align-items-center mb-4">
<h2 class="fw-bold m-0">My Orders</h2>

<span class="text-muted">
<%= orders.length %> <%= orders.length === 1 ? 'Order' : 'Orders' %>
</span>
</div>

<div class="row g-4">

<% orders.forEach(function(order){ %>

<div class="col-12">

<div class="card border-0 shadow-sm">

<!-- HEADER -->

<div class="card-header bg-transparent border-0 d-flex justify-content-between align-items-center pt-4 px-4">

<div class="d-flex align-items-center gap-3">

<span class="fw-semibold text-primary">
#<%= order.order_id %>
</span>

<span class="text-muted">•</span>

<span class="text-muted small">
<i class="bi bi-calendar3 me-1"></i>
<%= new Date(order.order_date).toLocaleDateString() %>
</span>

</div>

<!-- ORDER STATUS -->

<% if(order.order_status === 'delivered'){ %>

<span class="badge bg-success px-3 py-2">
Delivered
</span>

<% } else if(order.order_status === 'placed'){ %>

<span class="badge bg-primary px-3 py-2">
Processing
</span>

<% } else if(order.order_status === 'dispatched'){ %>

<span class="badge bg-info px-3 py-2">
Dispatched
</span>

<% } else if(order.order_status === 'cancelled'){ %>

<span class="badge bg-danger px-3 py-2">
Cancelled
</span>

<% } %>

</div>

<!-- BODY -->

<div class="card-body px-4">

<div class="row g-4">

<div class="col-md-5">

<h6 class="fw-semibold mb-2">
<%= order.full_name %>
</h6>

<p class="text-muted small mb-1">
<i class="bi bi-telephone"></i>
<%= order.mobile %>
</p>

<p class="text-muted small">
<i class="bi bi-geo-alt"></i>

<%= order.area %>, <%= order.city %>, <%= order.state %>
- <%= order.pincode %>

</p>

</div>

<div class="col-md-4">

<p class="mb-1">
<span class="text-muted small">Payment Method</span>
<br>
<span class="fw-medium"><%= order.payment_method %></span>
</p>

<p>

<span class="text-muted small">Payment Status</span>
<br>

<% if(order.payment_status === 'paid'){ %>

<span class="badge bg-success">
Paid
</span>

<% } else { %>

<span class="badge bg-warning text-dark">
Pending
</span>

<% } %>

</p>

</div>

<div class="col-md-3 text-md-end">

<span class="text-muted small d-block">
Total Amount
</span>

<span class="h4 fw-bold text-primary">
₹<%= order.total_amount %>
</span>

</div>

</div>

</div>

<!-- REFUND INFO -->

<% if(order.order_status === "cancelled" && order.payment_status === "paid"){ %>

<div class="alert alert-warning mx-4">

<strong>Order Cancelled</strong>
<br>

Refund Status :

<% if(order.refund_status === "pending"){ %>

<span class="text-warning">
Refund Processing...
</span>

<% } %>

<% if(order.refund_status === "completed"){ %>

<span class="text-success">
Refund Completed
</span>

<% } %>

</div>

<% } %>

<!-- FOOTER -->

<div class="card-footer bg-transparent border-top-0 pb-3 px-4">

<div class="d-flex gap-2 justify-content-end">

<a href="/print_order/<%= order.order_id %>">

<button class="btn btn-sm btn-outline-primary">
<i class="bi bi-eye me-1"></i> View Details
</button>

</a>

<!-- CANCEL BUTTON -->

<% if(order.order_status !== "cancelled" && order.order_status !== "delivered"){ %>

<a href="/cancle_order/<%= order.order_id %>"
onclick="return confirm('Are you sure to cancel this order?');">

<button class="btn btn-sm btn-outline-danger">
<i class="bi bi-trash me-1"></i> Cancel Order
</button>

</a>

<% } %>

<!-- TRACK -->

<a href="/order_tracking/<%= order.order_id %>"
class="btn btn-info btn-sm">

Track Order

</a>

<!-- PAY NOW -->

<% if(order.payment_status.toLowerCase() === "pending"
&& order.order_status !== "cancelled"){ %>

<a href="/accept_payment/<%= order.order_id %>">

<button class="btn btn-success btn-sm">

<i class="bi bi-credit-card me-1"></i> Pay Now

</button>

</a>

<% } %>

</div>

</div>

</div>

</div>

<% }) %>

</div>

<!-- EMPTY STATE -->

<% if(orders.length === 0){ %>

<div class="text-center py-5">

<i class="bi bi-bag-x display-1 text-muted"></i>

<h4 class="fw-semibold mt-3">
No orders yet
</h4>

<p class="text-muted">
Looks like you haven't placed any orders yet
</p>

<a href="/" class="btn btn-primary px-5 py-2">
Start Shopping
</a>

</div>

<% } %>

</div>

<link rel="stylesheet"
href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

<%- include('footer.ejs') %>