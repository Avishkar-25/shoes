  // ✅ OTP Modal साठी form submit handler
 function sendotp(event){
    event.preventDefault(); // form submit थांबवतो

    var mail = document.getElementById("email").value; 
    console.log(mail);

    $.ajax({
        url: "/send_otp_mail",
        method: "POST",
        data: { email: mail }

    }).done(function(res){

        console.log(res);

        // Email modal hide
        var emailModal = bootstrap.Modal.getInstance(document.getElementById('emailModal'));
        emailModal.hide();

        // OTP modal show
        var otpModal = new bootstrap.Modal(document.getElementById('getUserOtpModal'));
        otpModal.show();

    });
}

