<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>StepStyle - Premium Footwear</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome for icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&family=Montserrat:wght@800;900&display=swap" rel="stylesheet">
    <!-- jquery cdn -->
     <script src="https://code.jquery.com/jquery-3.7.1.js" integrity="sha256-eKhayi8LEQwp4NKxN+CfCh+3qOVUtJn3QNZ0TciWLP4=" crossorigin="anonymous"></script>
    
    <style>
        :root {
            --primary-color: #ff6b6b;
            --secondary-color: #4ecdc4;
            --dark-color: #2d3436;
            --light-color: #f9f9f9;
            --gray-color: #dfe6e9;
        }
        
        * {
            font-family: 'Poppins', sans-serif;
        }
        
        body {
            color: var(--dark-color);
            background-color: #fff;
            overflow-x: hidden;
        }
        
        h1, h2, h3, h4, h5, h6 {
            font-weight: 700;
        }
        
        .brand-logo {
            font-family: 'Montserrat', sans-serif;
            font-weight: 900;
            font-size: 2.2rem;
            color: var(--dark-color);
            text-decoration: none;
        }
        
        .brand-logo span {
            color: var(--primary-color);
        }
        
        .navbar-nav .nav-link {
            font-weight: 500;
            color: var(--dark-color);
            margin: 0 10px;
            transition: all 0.3s ease;
        }
        
        .navbar-nav .nav-link:hover {
            color: var(--primary-color);
        }
        .btn-outline-dark:hover {
    background-color: #000;
    color: #fff;
    transition: 0.3s;
}

.btn-danger:hover {
    background-color: #c82333;
    transition: 0.3s;
}
        </style>

         <!-- Navigation -->
    <nav class="navbar navbar-expand-lg navbar-light py-3 sticky-top bg-white">
        <div class="container">
            <a class="navbar-brand brand-logo" href="/"><span>Step</span>Style</a>
            
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto me-3">
                    <li class="nav-item">
                        <a class="nav-link active" href="/">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/product_list?cat=Mens">Men</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/product_list?cat=Womens">Women</a>
                    </li>
                  <li class="nav-item dropdown">
                          <a class="nav-link dropdown-toggle" href="#" id="kidsDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                          Kids
                           </a>
                  <ul class="dropdown-menu" aria-labelledby="kidsDropdown">
                   <li><a class="dropdown-item" href="/product_list?cat=KidBoys">Boys</a></li>
                     <li><a class="dropdown-item" href="/product_list?cat=KidGirls">Girls</a></li>
                </ul>
                  </li>

                    <li class="nav-item">
                        <a class="nav-link" href="/my_orders">My Orders</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/Sale">Sale</a>
                    </li>
                </ul>
                
           <div class="d-flex align-items-center">

    <!-- Cart -->
    <a href="/cart" class="me-4 text-dark position-relative cart-icon">
        <i class="fas fa-shopping-bag fa-lg"></i>
    </a>


  <!-- ✅ Login zalay tar Profile button show -->
<!-- Profile / Login -->
<div class="d-flex align-items-center gap-2">
  <% if(is_login){ %>
    <!-- Profile Button -->
    <a href="/profile" class="btn btn-outline-dark d-flex align-items-center px-3 py-2 shadow-sm">
      <i class="fa fa-user me-2"></i> Profile
    </a>

    <!-- Logout Button -->
    <a href="/logout" class="btn btn-danger d-flex align-items-center px-3 py-2 shadow-sm">
      <i class="fa fa-sign-out-alt me-2"></i> Logout
    </a>

  <% } else { %>
    <!-- Profile (Login Modal) -->
    <a href="#"
       onclick="saveRedirect('/profile')"
       data-bs-toggle="modal"
       data-bs-target="#emailModal"
       class="btn btn-outline-dark d-flex align-items-center px-3 py-2 shadow-sm">
       <i class="fa fa-user me-2"></i> Profile
    </a>
  <% } %>
</div>
  
<!-- Anywhere in your navbar or header -->

</div>

        </div>
    </nav>





    <!-- Bootstrap 5 CSS -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<!-- Modal -->
<div class="modal fade" id="authModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content p-4">
      <form action="/customer_register"  method="post">
      <h4 class="text-center mb-3">Create Account</h4>
        
      <!-- Name -->
      <div class="mb-3">
        <label class="form-label">Name</label>
        <input type="text" class="form-control" name="name" placeholder="Enter Name">
      </div>

      <!-- Email -->
      <div class="mb-3">
        <label class="form-label">Email</label>
        <input type="email" class="form-control" name="email" placeholder="Enter Email">
      </div>

      <!-- Mobile -->
      <div class="mb-3">
        <label class="form-label">Mobile</label>
        <input type="text" class="form-control" name="mobile" placeholder="Enter Mobile">
      </div>

      <!-- Password -->
      <div class="mb-3">
        <label class="form-label">Password</label>
        <input type="password" class="form-control" name="password" placeholder="Enter Password">
      </div>

      <button class="btn btn-primary w-100">Register</button>

      <hr>
</form>
      <p class="text-center mb-0">
        Already have account? 
        <a href="#"   data-bs-toggle="modal" 
        data-bs-target="#loginModal">Login</a>
      </p>

    </div>
  </div>
</div>

<!-- login modal  -->

<!-- Login Modal -->
<div class="modal fade" id="loginModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content p-4">
  <form action="/customer_login" method="post">
      <h4 class="text-center mb-3">Login</h4>

      <!-- Email -->
      <div class="mb-3">
        <label>Email</label>
        <input type="email" name="login_email" class="form-control" placeholder="Enter Email">
      </div>

      <!-- Password -->
      <div class="mb-3">
        <label>Password</label>
        <input type="password" name="login_password" class="form-control" placeholder="Enter Password">
      </div>

      <!-- Button -->
      <button class="btn btn-dark w-100" >Login</button>
     </form>
      <!-- Optional -->
      <p class="text-center mt-3 mb-0">
        Don't have account? 
        <a href="" data-bs-toggle="modal" data-bs-target="#authModal">Register</a>
      </p>

    </div>
  </div>
</div>






