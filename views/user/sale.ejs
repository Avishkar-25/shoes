<%- include("navbar.ejs") %>
  <!-- Bootstrap 5 CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  
  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&family=Roboto:wght@300;400;500&display=swap" rel="stylesheet">
  
  <!-- Bootstrap Icons -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  
  <style>
    body {
      font-family: 'Roboto', sans-serif;
      background-color: #f8f9fa;
      color: #212529;
    }
   
    
    .brand-accent {
      color: #e2714a;
    }
    .hero-section {
      background: linear-gradient(135deg, #0d6efd 0%, #0a58ca 100%);
      color: white;
      padding: 4rem 0;
      border-radius: 0 0 2rem 2rem;
      margin-bottom: 3rem;
    }
    .hero-title {
      font-size: 3.5rem;
      font-weight: 700;
      line-height: 1.2;
    }
    .hero-subtitle {
      font-size: 1.2rem;
      opacity: 0.95;
      margin-bottom: 2rem;
    }
    .btn-terracotta {
      background-color: #e2714a;
      color: white;
      border: none;
      padding: 12px 30px;
      font-weight: 500;
      border-radius: 50px;
      transition: all 0.3s ease;
    }
    .btn-terracotta:hover {
      background-color: #c55a3a;
      color: white;
      transform: translateY(-2px);
      box-shadow: 0 10px 20px rgba(0,0,0,0.1);
    }
    .btn-outline-light:hover {
      background-color: white;
      color: #0d6efd;
    }
    .category-card {
      border: none;
      border-radius: 15px;
      overflow: hidden;
      transition: all 0.3s ease;
      cursor: pointer;
      box-shadow: 0 5px 15px rgba(0,0,0,0.05);
    }
    .category-card:hover {
      transform: translateY(-10px);
      box-shadow: 0 15px 30px rgba(0,0,0,0.1);
    }
    .category-img {
      height: 200px;
      object-fit: cover;
    }
    .product-card {
      border: none;
      border-radius: 15px;
      overflow: hidden;
      transition: all 0.3s ease;
      box-shadow: 0 5px 15px rgba(0,0,0,0.05);
    }
    .product-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 15px 30px rgba(0,0,0,0.1);
    }
    .product-img {
      height: 250px;
      object-fit: cover;
    }
    .badge-sale {
      background-color: #e2714a;
      color: white;
      font-weight: 500;
      padding: 5px 10px;
      border-radius: 50px;
      position: absolute;
      top: 10px;
      left: 10px;
      z-index: 2;
    }
    .price {
      font-size: 1.3rem;
      font-weight: 700;
      color: #0d6efd;
    }
    .old-price {
      text-decoration: line-through;
      color: #6c757d;
      margin-left: 10px;
      font-size: 1rem;
    }
    .section-title {
      font-weight: 700;
      margin-bottom: 2rem;
      position: relative;
      display: inline-block;
    }
    .section-title:after {
      content: '';
      position: absolute;
      bottom: -10px;
      left: 0;
      width: 60px;
      height: 4px;
      background-color: #e2714a;
      border-radius: 2px;
    }
   
   
  </style>
</head>
<body>



<!-- Hero Section -->
<section class="hero-section">
  <div class="container">
    <div class="row align-items-center">
      <div class="col-lg-6">
        <h1 class="hero-title">Step Into<br>Comfort & Style</h1>
        <p class="hero-subtitle">Discover the latest collection of sneakers, running shoes, and casual footwear. Up to 40% off on new arrivals.</p>
        <div class="d-flex gap-3">
          <button class="btn btn-terracotta btn-lg">Shop Now <i class="bi bi-arrow-right"></i></button>
          <button class="btn btn-outline-light btn-lg">Explore</button>
        </div>
      </div>
      <div class="col-lg-6 text-center">
        <img src="https://images.unsplash.com/photo-1549298916-b41d501d3772?w=600&auto=format&fit=crop" alt="Hero Shoes" class="img-fluid rounded-4 shadow">
      </div>
    </div>
  </div>
</section>

<!-- Categories -->
<div class="container mb-5">
  <h2 class="section-title">Shop by Category</h2>
  <div class="row g-4">
    <div class="col-md-4">
      <div class="card category-card">
        <img src="https://images.unsplash.com/photo-1606107557195-0e29a4b5b4aa?w=600&auto=format&fit=crop" class="card-img-top category-img" alt="Men Shoes">
        <div class="card-body text-center">
          <h5 class="card-title">Men's Collection</h5>
          <p class="text-muted">12 items</p>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card category-card">
        <img src="https://images.unsplash.com/photo-1543163521-1bf539c55dd2?w=600&auto=format&fit=crop" class="card-img-top category-img" alt="Women Shoes">
        <div class="card-body text-center">
          <h5 class="card-title">Women's Collection</h5>
          <p class="text-muted">18 items</p>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card category-card">
        <img src="https://images.unsplash.com/photo-1607522370275-f14206ab5c1d?w=600&auto=format&fit=crop" class="card-img-top category-img" alt="Kids Shoes">
        <div class="card-body text-center">
          <h5 class="card-title">Kids' Collection</h5>
          <p class="text-muted">8 items</p>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Featured Products -->
<div class="container mb-5">
  <div class="d-flex justify-content-between align-items-center">
    <h2 class="section-title">Featured Products</h2>
    <a href="#" class="text-decoration-none">View All <i class="bi bi-arrow-right"></i></a>
  </div>
  
  <div class="row g-4">
    <!-- Product 1 -->
    <div class="col-lg-3 col-md-6">
      <div class="card product-card position-relative">
        <span class="badge-sale">-25%</span>
        <img src="https://images.unsplash.com/photo-1542291026-7eec264c27ff?w=600&auto=format&fit=crop" class="card-img-top product-img" alt="Product">
        <div class="card-body">
          <h6 class="card-title">Nike Air Max</h6>
          <p class="text-muted small">Men's Running Shoes</p>
          <div>
            <span class="price">$89.99</span>
            <span class="old-price">$119.99</span>
          </div>
          <button class="btn btn-primary w-100 mt-3">Add to Cart</button>
        </div>
      </div>
    </div>
    
    <!-- Product 2 -->
    <div class="col-lg-3 col-md-6">
      <div class="card product-card">
        <img src="https://images.unsplash.com/photo-1515955656352-a1fa3ffcd111?w=600&auto=format&fit=crop" class="card-img-top product-img" alt="Product">
        <div class="card-body">
          <h6 class="card-title">Adidas Ultraboost</h6>
          <p class="text-muted small">Women's Running</p>
          <div>
            <span class="price">$129.99</span>
          </div>
          <button class="btn btn-primary w-100 mt-3">Add to Cart</button>
        </div>
      </div>
    </div>
    
    <!-- Product 3 -->
    <div class="col-lg-3 col-md-6">
      <div class="card product-card">
        <span class="badge-sale">New</span>
        <img src="https://images.unsplash.com/photo-1608231387042-66d1773070a5?w=600&auto=format&fit=crop" class="card-img-top product-img" alt="Product">
        <div class="card-body">
          <h6 class="card-title">Puma RS-X</h6>
          <p class="text-muted small">Unisex Lifestyle</p>
          <div>
            <span class="price">$79.99</span>
          </div>
          <button class="btn btn-primary w-100 mt-3">Add to Cart</button>
        </div>
      </div>
    </div>
    
    <!-- Product 4 -->
    <div class="col-lg-3 col-md-6">
      <div class="card product-card">
        <span class="badge-sale">-15%</span>
        <img src="https://images.unsplash.com/photo-1584735175315-9d5df23860e6?w=600&auto=format&fit=crop" class="card-img-top product-img" alt="Product">
        <div class="card-body">
          <h6 class="card-title">New Balance 574</h6>
          <p class="text-muted small">Classic Casual</p>
          <div>
            <span class="price">$74.99</span>
            <span class="old-price">$89.99</span>
          </div>
          <button class="btn btn-primary w-100 mt-3">Add to Cart</button>
        </div>
      </div>
    </div>
  </div>
</div>






<!-- Bootstrap JS -->
<!-- <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script> -->
</body>
</html>
<%- include("footer.ejs") %>
