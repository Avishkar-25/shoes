<%- include('navbar.ejs') %>

<!-- MAIN CONTENT WRAPPER -->
<div class="main-content">

    <!-- Add Button -->
    <div class="container mb-4">
        <button type="button" class="btn btn-gradient shadow"
                data-bs-toggle="modal" data-bs-target="#productStyleModal">
            ➕ Add Product Style
        </button>
    </div>

    <!-- Modal -->
    <div class="modal fade" id="productStyleModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 rounded-4 shadow-lg">

                <!-- Header -->
                <div class="modal-header text-white modal-gradient rounded-top-4">
                    <h5 class="modal-title">🎨 Add Product Style</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>

                <!-- Body -->
                <div class="modal-body p-4">
                    <form action="/admin/save_product_style" method="post" enctype="multipart/form-data">

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Product Name</label>
                            <input type="text" name="product_style_name"
                                   class="form-control rounded-3"
                                   placeholder="Enter product name" required>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Status</label>
                            <select name="product_style_status" class="form-select rounded-3" required>
                                <option value="">Select status</option>
                                <option value="active">Active</option>
                                <option value="inactive">Inactive</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Product Image</label>
                            <input type="file" name="product_style_image"
                                   class="form-control rounded-3">
                        </div>

                        <div class="d-grid gap-2">
                            <button class="btn btn-success rounded-3">
                                💾 Save
                            </button>
                            <button type="button" class="btn btn-outline-secondary rounded-3"
                                    data-bs-dismiss="modal">
                                Cancel
                            </button>
                        </div>

                    </form>
                </div>

            </div>
        </div>
    </div>

    <!-- Product List -->
    <div class="container mt-4">
        <div class="card border-0 shadow-lg rounded-4">

            <div class="card-header table-gradient text-white
                        d-flex justify-content-between align-items-center
                        rounded-top-4">
                <h5 class="mb-0">📋 Product Style List</h5>
            </div>

            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle text-center mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Action</th>
                                <th>#</th>
                                <th>Name</th>
                                <th>Status</th>
                                <th>Image</th>
                            </tr>
                        </thead>

                        <tbody>
                            <% if (result.length > 0) { %>
                                <% result.forEach((row, i) => { %>
                                    <tr>
                                        <td>
                                            <a href="/admin/edit_product_style/<%= row.product_style_id %>"
                                               class="btn btn-sm btn-warning me-1">✏️</a>

                                            <a href="/admin/delete_product_style/<%= row.product_style_id %>"
                                               class="btn btn-sm btn-danger"
                                               onclick="return confirm('Are you sure?')">🗑</a>
                                        </td>

                                        <td><%= i + 1 %></td>

                                        <td class="fw-semibold">
                                            <%= row.product_style_name %>
                                        </td>

                                        <td>
                                            <span class="badge <%= row.product_style_status === 'active'
                                                ? 'bg-success' : 'bg-danger' %>">
                                                <%= row.product_style_status %>
                                            </span>
                                        </td>

                                        <td>
                                            <% if (row.product_style_image) { %>
                                                <img src="/styles/<%= row.product_style_image %>"
                                                     class="img-thumb">
                                            <% } else { %>
                                                <span class="text-muted">No Image</span>
                                            <% } %>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="5" class="text-muted py-4">
                                        No product styles found
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
    </div>

</div> <!-- END main-content -->

<!-- STYLES -->
<style>
.main-content {
    margin-left: 240px;   /* sidebar width */
    margin-top: 80px;     /* navbar height */
    padding: 20px;
    transition: all 0.3s ease;
}

/* Mobile */
@media (max-width: 768px) {
    .main-content {
        margin-left: 0;
        margin-top: 80px;
    }
}

.btn-gradient {
    background: linear-gradient(135deg, #667eea, #764ba2);
    color: #fff;
    border-radius: 30px;
    padding: 10px 25px;
}

.modal-gradient {
    background: linear-gradient(135deg, #1e3c72, #2a5298);
}

.table-gradient {
    background: linear-gradient(135deg, #11998e, #38ef7d);
}

.img-thumb {
    width: 60px;
    height: 60px;
    object-fit: cover;
    border-radius: 10px;
    box-shadow: 0 4px 8px rgba(0,0,0,0.2);
}

.table-hover tbody tr:hover {
    background-color: #f8f9fa;
    transform: scale(1.01);
    transition: 0.2s ease;
}
</style>

<%- include('footer.ejs') %>
