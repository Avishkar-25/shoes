<%- include('navbar.ejs') %>

<div class="container mt-5">
    <div class="row justify-content-center ">
        <div class="col-md-6 mt-5">
            <div class="card shadow-lg border-0 rounded-4">
                
                <!-- Card Header -->
                <div class="card-header bg-dark text-white text-center rounded-top-4">
                    <h4 class="mb-0">✏️ Edit Product Brand</h4>
                </div>

                <!-- Card Body -->
                <div class="card-body p-4">
                    <form action="/admin/update_product_brand" method="post">
            
                        <!-- Brand Name -->
                        <div class="mb-3">
                             <input type="hidden" name="product_brand_id"  value="<%= result[0].product_brand_id %>" id="">
                            <label class="form-label fw-semibold">Brand Name</label>
                            <input type="text"
                                   name="product_brand_name"
                                   value="<%= result[0].product_brand_name %>" 
                                   class="form-control rounded-3"
                                   placeholder="Enter brand name"
                                   required>
                        </div>

                        <!-- Brand Status -->
                        <div class="mb-4">
                            <label class="form-label fw-semibold">Brand Status</label>
                            <select name="product_brand_status"
                                    class="form-select rounded-3"
                                    required>
                                <option value="">Select status</option>
                                <option value="active"
                                    <%= result[0].product_brand_status === 'active' ? 'selected' : '' %>>
                                    Active
                                </option>
                                <option value="inactive"
                                    <%= result[0].product_brand_status === 'inactive' ? 'selected' : '' %>>
                                    Inactive
                                </option>
                            </select>
                        </div>

                        <!-- Buttons -->
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-success rounded-3 fw-semibold">
                                💾 Update Brand
                            </button>
                            <a href="/product_brands" class="btn btn-outline-secondary rounded-3">
                                ⬅ Back to Brand List
                            </a>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('footer.ejs') %>
