<%- include('navbar.ejs') %>

<style>
/* Admin content spacing for sidebar */
.admin-content{
  margin-left:250px; /* sidebar width */
  margin-top:80px;   /* top navbar height */
  padding:20px;
}

/* Total dispatch orders box */
.total-orders-box{
  background:#f8f9fa;
  border-left:5px solid #198754; /* green for dispatch */
  padding:15px 20px;
  margin-bottom:20px;
  font-weight:600;
  border-radius:8px;
  box-shadow:0 2px 5px rgba(0,0,0,0.1);
}

/* Responsive */
@media(max-width:768px){
  .admin-content{
    margin-left:0;
    margin-top:90px;
  }
}
</style>

<div class="admin-content">

  <!-- Total Dispatch Orders Box -->
  <div class="total-orders-box">
    Total Dispatch Orders: <%= orders.length %>
  </div>

  <h2 class="mb-4">Dispatch Orders</h2>

  <table class="table table-bordered text-center">
    <thead class="table-dark">
      <tr>
        <th>Order ID</th>
        <th>Customer</th>
        <th>Product</th>
        <th>Amount</th>
        <th>Payment</th>
        <th>Action</th>
      </tr>
    </thead>
    <tbody>
      <% if(orders.length > 0){ %>
        <% orders.forEach(function(order, i){ %>
          <tr>
            <td>#<%= i +1   %></td>
            <td><%= order.full_name %></td>
            <td><%= order.product_name %></td>
            <td>₹ <%= order.total_amount %></td>
            <td><%= order.payment_method %></td>
            <td>
              <a href="/admin/deliver_order/<%= order.order_id %>"
                 class="btn btn-success btn-sm"
                 onclick="return confirm('Mark as Delivered?')">
                 Deliver
              </a>
            </td>
          </tr>
        <% }) %>
      <% } else { %>
        <tr>
          <td colspan="6">No Dispatch Orders</td>
        </tr>
      <% } %>
    </tbody>
  </table>

</div>

<%- include('footer.ejs') %>