<%- include('navbar.ejs') %>

<div class="main-content">
  <div class="container mt-4">

    <div class="card shadow-lg border-0 rounded-4 p-4">
      <h4 class="mb-4 text-primary fw-bold">Update Product</h4>

      <form action="/admin/update_product" method="post" enctype="multipart/form-data">

        <input type="hidden" name="product_id" value="<%= product.product_id %>">
        <input type="hidden" name="old_image" value="<%= product.product_main_image %>">

        <!-- Product Name -->
        <div class="mb-3">
          <label class="form-label fw-semibold">Product Name</label>
          <input type="text" name="product_name"
                 value="<%= product.product_name %>"
                 class="form-control rounded-3" required>
        </div>

        <!-- Market Price -->
        <div class="mb-3">
          <label class="form-label fw-semibold">Market Price (₹)</label>
          <input type="number" name="product_market_price"
                 value="<%= product.product_market_price %>"
                 class="form-control rounded-3" required>
        </div>

        <!-- Selling Price -->
        <div class="mb-3">
          <label class="form-label fw-semibold">Selling Price (₹)</label>
          <input type="number" name="product_price"
                 value="<%= product.product_price %>"
                 class="form-control rounded-3" required>
        </div>

        <!-- Description -->
        <div class="mb-3">
          <label class="form-label fw-semibold">Description</label>
          <textarea name="product_description"
                    class="form-control rounded-3" rows="3"><%= product.product_description %></textarea>
        </div>

        <!-- Rating -->
        <div class="mb-3">
          <label class="form-label fw-semibold">Rating</label>
          <input type="number" step="0.1" min="0" max="5"
                 name="product_rating"
                 value="<%= product.product_rating %>"
                 class="form-control rounded-3">
        </div>

        <!-- Trending -->
        <div class="mb-3">
          <label class="form-label fw-semibold">Trending</label>
          <select name="product_is_trending" class="form-select rounded-3">
            <option value="1" <%= product.product_is_trending == 1 ? 'selected' : '' %>>Yes</option>
            <option value="0" <%= product.product_is_trending == 0 ? 'selected' : '' %>>No</option>
          </select>
        </div>

        <!-- Brand -->
        <div class="mb-3">
          <label class="form-label fw-semibold">Brand</label>
          <select name="product_brand_id" class="form-select rounded-3">
            <% brands.forEach(b => { %>
              <option value="<%= b.product_brand_id %>"
                <%= product.product_brand_id == b.product_brand_id ? 'selected' : '' %>>
                <%= b.product_brand_name %>
              </option>
            <% }) %>
          </select>
        </div>

        <!-- Style -->
        <div class="mb-3">
          <label class="form-label fw-semibold">Style</label>
          <select name="product_style_id" class="form-select rounded-3">
            <% styles.forEach(s => { %>
              <option value="<%= s.product_style_id %>"
                <%= product.product_style_id == s.product_style_id ? 'selected' : '' %>>
                <%= s.product_style_name %>
              </option>
            <% }) %>
          </select>
        </div>

        <!-- Type -->
        <div class="mb-3">
          <label class="form-label fw-semibold">Type</label>
          <select name="product_type_id" class="form-select rounded-3">
            <% types.forEach(t => { %>
              <option value="<%= t.product_type_id %>"
                <%= product.product_type_id == t.product_type_id ? 'selected' : '' %>>
                <%= t.product_type_name %>
              </option>
            <% }) %>
          </select>
        </div>

        <!-- Product For -->
        <div class="mb-3">
          <label class="form-label fw-semibold">Product For</label>
         <select name="product_for" class="form-select rounded-3">
  <option value="male" <%= product.product_for=='male'?'selected':'' %>>Men</option>
  <option value="female" <%= product.product_for=='female'?'selected':'' %>>Women</option>
  <option value="kids" <%= product.product_for=='kids'?'selected':'' %>>Kids</option>
</select>
        </div>

        <!-- Kid Type -->
       <div class="mb-3">
  <label class="form-label fw-semibold">Kid Type</label>
  <select name="product_kid_type" class="form-select rounded-3">
    <option value="">Select</option>
    <option value="boys" <%= product.product_kid_type=='boys'?'selected':'' %>>Boys</option>
    <option value="girls" <%= product.product_kid_type=='girls'?'selected':'' %>>Girls</option>
    <option value="both" <%= product.product_kid_type=='both'?'selected':'' %>>Both</option>
  </select>
</div>

        <!-- Offer Expiry Date -->
        <div class="mb-3">
          <label class="form-label fw-semibold">Offer Expiry Date</label>
          <input type="date" name="offer_expiry_date"
                 value="<%= product.offer_expiry_date %>"
                 class="form-control rounded-3">
        </div>

        <!-- Product Added Date -->
        <div class="mb-3">
          <label class="form-label fw-semibold">Product Added Date</label>
          <input type="date" name="product_added_date"
                 value="<%= product.product_added_date %>"
                 class="form-control rounded-3">
        </div>

        <!-- Stock -->
        <div class="mb-3">
          <label class="form-label fw-semibold">Stock Quantity</label>
          <input type="number" name="product_stock"
                 value="<%= product.product_stock %>"
                 class="form-control rounded-3">
        </div>

        <!-- Color -->
        <div class="mb-3">
          <label class="form-label fw-semibold">Color</label>
          <input type="text" name="product_color"
                 value="<%= product.product_color %>"
                 class="form-control rounded-3">
        </div>

        <!-- Status -->
        <div class="mb-3">
          <label class="form-label fw-semibold">Status</label>
          <select name="status" class="form-select rounded-3">
            <option value="1" <%= product.status==1?'selected':'' %>>Active</option>
            <option value="0" <%= product.status==0?'selected':'' %>>Inactive</option>
          </select>
        </div>

        <!-- Image Upload -->
        <div class="mb-3">
          <label class="form-label fw-semibold">Upload New Image</label>
          <input type="file" name="product_main_image" class="form-control rounded-3">
        </div>

        <!-- Current Image -->
        <div class="mb-3">
          <label class="form-label fw-semibold">Current Image</label><br>
          <img src="/product/<%= product.product_main_image %>"
               width="120" class="rounded shadow-sm">
        </div>

        <button class="btn btn-success px-4 py-2 rounded-3 fw-semibold">
          Update Product
        </button>

      </form>
    </div>

  </div>
</div>

<%- include('footer.ejs') %>

<style>
.main-content {
    margin-right: 250px;
    padding: 30px;
}
.card {
    background: #ffffff;
}
.form-control:focus,
.form-select:focus {
    box-shadow: 0 0 8px rgba(0,123,255,0.3);
    border-color: #0d6efd;
}
</style>