    product_description text
    product_main_image varchar(300)
    product_rating decimal
    product_is_trending enum('yes','no')
    product_brand_id int
    product_style_id int
    product_for enum('male','female','kids')
    product_kid_type enum('boys','girls')
    product_type_id int
    offer_expiry_date date
    product_added_date datetime
    product_stock int
    product_color varchar(100)
    status enum('active','inactive') -->